# Print numbers 1 to 10
for i in range(1, 11):
    print(i)

# Sum only even numbers from 1 to 20
total = 0
for n in range(1, 21):
    if n % 2 == 0:
        total += n
print("Sum of even numbers:", total)

# While loop: countdown
count = 5
while count > 0:
    print(count)
    count -= 1
print("Go!")